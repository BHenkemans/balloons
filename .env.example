DOMJUDGE_URL=
DOMJUDGE_USER=
DOMJUDGE_PASS=
DOMJUDGE_CONTEST_ID=

# Comma-separated DOMjudge group ids whose balloons should be hidden entirely.
# Example: HIDE_GROUP_IDS=observers,jury
HIDE_GROUP_IDS=

# Comma-separated DOMjudge group ids whose teams still get balloons but never
# the first-solve flag. The first-solve flag is awarded to the first team NOT
# in this set to solve each problem.
# Example: NO_FIRST_SOLVE_GROUP_IDS=organization,system
NO_FIRST_SOLVE_GROUP_IDS=

# Printer backend: "escpos" (render Typst to PNG, dither, and stream raster
# bytes to a thermal printer over TCP) or "ipp" (render Typst to PDF and submit
# to an IPP queue). Tickets print when a new balloon is detected; reprints are
# deduped via STATE_DB.
PRINTER_KIND=escpos

# Full IPP URI for the printer queue. Required when PRINTER_KIND=ipp.
# Example: PRINTER_IPP_URI=ipp://printer.local:631/ipp/print
PRINTER_IPP_URI=

# host:port of the ESC/POS thermal printer's raw-print socket (typically 9100).
# Required when PRINTER_KIND=escpos.
# Example: PRINTER_ESCPOS_ADDR=192.168.1.50:9100
PRINTER_ESCPOS_ADDR=

# Printer head width in dots. Defaults to 576 (80mm @ 203dpi). Use 384 for
# 58mm printers. The Typst page width is derived from this and the assumed
# 203 DPI head; the page is then rendered at 2× this width and box-filtered
# down so anti-aliased edges and colored fills convert cleanly to 1-bit.
PRINTER_ESCPOS_WIDTH=

# Path to the Typst template used for ticket rendering. Defaults to
# templates/balloon.typ for both backends. The IPP driver invokes it with
# `--input theme=color`; the ESC/POS driver passes `--input theme=thermal`
# plus `--input page_width_mm=<x>` so the same template handles both layouts.
PRINTER_TEMPLATE=

# Path to the SQLite file that tracks ticket lifecycle (printed_at,
# delivered_at). Defaults to balloons.db in the working directory. Deleting
# the file resets the dedupe — all currently-pending balloons will reprint
# on the next refresh.
STATE_DB=

# IANA timezone name used to render the ticket datetime (e.g. Europe/Amsterdam,
# America/Los_Angeles, UTC). Defaults to the server process's local timezone —
# set this explicitly when the server runs in a container/systemd unit that
# inherits UTC, otherwise printed tickets will be off by the UTC offset.
# Example: CONTEST_TZ=Europe/Amsterdam
CONTEST_TZ=

# Public base URL of this server, used to build the QR code printed on every
# ticket (`<SCAN_BASE_URL>/scan?id=<balloon_id>`). When a runner scans the
# QR, they land on a mobile page that auto-marks the balloon delivered after
# a 5-second undo window. If unset, falls back to `http://<hostname><ADDR>`
# (useful on a contest LAN); set explicitly when behind a reverse proxy or
# when the runner's phone can't resolve the host by name.
# Example: SCAN_BASE_URL=https://balloons.contest.local
SCAN_BASE_URL=
