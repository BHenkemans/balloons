DOMJUDGE_URL=
DOMJUDGE_USER=
DOMJUDGE_PASS=
DOMJUDGE_CONTEST_ID=

# Dev-only: redirect the event-feed stream to a local mock (see cmd/mockfeed).
# /balloons, /teams, /state still hit DOMJUDGE_URL. Leave empty in prod.
# Example: DOMJUDGE_EVENTFEED_URL=http://localhost:8090
DOMJUDGE_EVENTFEED_URL=

# Comma-separated DOMjudge group ids whose balloons should be hidden entirely.
# Example: HIDE_GROUP_IDS=observers,jury
HIDE_GROUP_IDS=

# Comma-separated DOMjudge group ids whose teams still get balloons but never
# the first-solve flag. The first-solve flag is awarded to the first team NOT
# in this set to solve each problem.
# Example: NO_FIRST_SOLVE_GROUP_IDS=organization,system
NO_FIRST_SOLVE_GROUP_IDS=

# Printer backend: "noop" (log only), "ipp" (render Typst to PDF and submit to
# an IPP queue), or "escpos" (render Typst to PNG, dither, and stream raster
# bytes to a thermal printer over TCP). Tickets print when a new balloon is
# detected; reprints are deduped via STATE_DB.
PRINTER_KIND=noop

# Full IPP URI for the printer queue. Required when PRINTER_KIND=ipp.
# Example: PRINTER_IPP_URI=ipp://printer.local:631/ipp/print
PRINTER_IPP_URI=

# host:port of the ESC/POS thermal printer's raw-print socket (typically 9100).
# Required when PRINTER_KIND=escpos.
# Example: PRINTER_ESCPOS_ADDR=192.168.1.50:9100
PRINTER_ESCPOS_ADDR=

# Printer head width in dots. Defaults to 576 (80mm @ 203dpi). Use 384 for
# 58mm printers. The Typst PPI is computed so an 80mm page renders to exactly
# this width.
PRINTER_ESCPOS_WIDTH=

# Path to the Typst template used for ticket rendering. Defaults to
# templates/balloon.typ; override to swap layouts (e.g. receipt format).
PRINTER_TEMPLATE=

# Path to the SQLite file that tracks ticket lifecycle (printed_at,
# delivered_at). Defaults to balloons.db in the working directory. Deleting
# the file resets the dedupe — all currently-pending balloons will reprint
# on the next refresh.
STATE_DB=
