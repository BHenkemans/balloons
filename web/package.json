{
  "name": "balloons-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i src/styles.css -o dist/styles.css --minify",
    "build:js": "esbuild src/main.ts src/runner.ts --bundle --format=esm --target=es2022 --outdir=dist",
    "build": "npm run build:css && npm run build:js",
    "watch:css": "tailwindcss -i src/styles.css -o dist/styles.css --watch",
    "watch:js": "esbuild src/main.ts src/runner.ts --bundle --format=esm --target=es2022 --outdir=dist --watch",
    "watch": "concurrently -n css,js -c cyan,green \"npm:watch:css\" \"npm:watch:js\""
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.3",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "devDependencies": {
    "@bufbuild/protoc-gen-es": "^2.2.3",
    "@tailwindcss/cli": "^4.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.24.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
